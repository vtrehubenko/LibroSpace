generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books LibraryFile[]
}

model LibraryFile {
  id              String    @id @default(cuid())
  title           String
  author          String?
  fileUrl         String
  coverUrl        String?
  format          String    // "PDF" | "EPUB"
  category        String?
  readingProgress Int       @default(0)
  currentPage     Int       @default(1)
  totalPages      Int?
  isFavorite      Boolean   @default(false)
  lastOpenedAt    DateTime?
  fileKey         String?   // UploadThing file key
  coverKey        String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
